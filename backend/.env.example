# Server 
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB 
# Local:  mongodb://localhost:27017/prism
# Docker: mongodb://prism:prism_dev_password@localhost:27017/prism?authSource=admin
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/prism
MONGODB_URI=mongodb://localhost:27017/prism

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth 2.0 
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Gemini AI 
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Rate Limiting 
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Cookie 
COOKIE_SECRET=replace_with_32_char_random_string
